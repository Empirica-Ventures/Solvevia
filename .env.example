# Environment variables for api/contact.js (the contact-form backend).
# Set real values in Vercel -> Project Settings -> Environment Variables.
# Never put real values in this file or commit them anywhere in this repo.
#
# The mailbox is provisioned via InboxKit (backed by a real Google Workspace
# or Microsoft 365 account) — it generates the SMTP host/port/user/app-password
# below once the mailbox exists.

# --- SMTP connection (required) ---
SMTP_HOST=
SMTP_PORT=

# "true" for port 465 (implicit TLS), "false" for 587/25 (STARTTLS).
# Optional — inferred from SMTP_PORT (465 => true) when omitted.
SMTP_SECURE=

SMTP_USER=
SMTP_PASS=

# --- Delivery (required) ---
# Inbox that receives contact-form submissions.
MAIL_TO=

# --- Delivery (optional) ---
# "From" address on outgoing mail. Defaults to SMTP_USER if unset — most
# providers require the From address to match the authenticated mailbox.
MAIL_FROM=

# Used in the notification email's subject line. Defaults to "website".
SITE_NAME=Solvevia
